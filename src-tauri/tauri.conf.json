{
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "Tunxkit Translator",
   "version": "1.0.0",
   "identifier": "com.tunxkit.translator",
   "build": {
      "devUrl": "http://localhost:1420",
      "frontendDist": "../dist",
      "beforeDevCommand": "npm run dev",
      "beforeBuildCommand": "npm run build"
   },
   "app": {
      "withGlobalTauri": true,
      "macOSPrivateApi": true,
      "windows": [
         {
            "label": "main",
            "title": "Tunxkit Translator",
            "width": 600,
            "height": 400,
            "minWidth": 400,
            "minHeight": 200,
            "center": true,
            "transparent": false,
            "decorations": false,
            "alwaysOnTop": true,
            "resizable": true,
            "skipTaskbar": false
         }
      ],
      "security": {
         "csp": "default-src 'self' http://localhost:* https://localhost:*; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com http://localhost:*; font-src 'self' https://fonts.gstatic.com http://localhost:*; connect-src 'self' ipc://localhost wss: ws: https: http://localhost:*; img-src 'self' data:"
      }
   },
   "bundle": {
      "active": true,
      "targets": "all",
      "resources": {
         "../scripts/*": "scripts/"
      },
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "macOS": {
         "entitlements": "Entitlements.plist",
         "frameworks": [],
         "minimumSystemVersion": "13.0"
      }
   }
}
